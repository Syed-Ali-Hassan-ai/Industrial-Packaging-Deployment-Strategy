# ── Copy this file to .env and fill in real values ──────────────────────────
# The .env file is gitignored. Never commit real secrets to version control.

# Required: OpenAI API key (used by the agent and by the eval judge)
OPENAI_API_KEY=sk-...

# ChromaDB connection (change only if running Chroma on a non-default port)
CHROMA_HOST=localhost
CHROMA_PORT=8000

# "server" connects to a running ChromaDB HTTP server (Docker)
# "embedded" uses an in-process ChromaDB instance (local dev without Docker)
CHROMA_MODE=embedded

# Name of the ChromaDB collection that stores the knowledge base
COLLECTION_NAME=packaging_kb

# Path to the directory containing .txt knowledge-base documents
DATA_DIR=data
